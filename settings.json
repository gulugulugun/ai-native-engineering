{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /data/workspace/.codebuddy/hooks/session_start_context.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|execute_command",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /data/workspace/.codebuddy/hooks/pretool_guard.py",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Write|Edit|Delete|write_to_file|replace_in_file|delete_file",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /data/workspace/.codebuddy/hooks/pretool_guard.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|write_to_file|replace_in_file",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /data/workspace/.codebuddy/hooks/post_lint_check.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
